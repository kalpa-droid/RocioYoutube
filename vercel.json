{
  "version": 2,
  "builds": [
    {
      "src": "api/info.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/subtitles.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/info",
      "dest": "api/info.py"
    },
    {
      "src": "/api/subtitles",
      "dest": "api/subtitles.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
